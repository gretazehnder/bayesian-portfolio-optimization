labels = function(x) paste0(round(x * 100, 0), "%"),
breaks = seq(-0.4, 0, by = 0.1)
) +
labs(title    = "Drawdown",
subtitle = period_label,
x = NULL, y = "Drawdown", fill = NULL) +
theme_portfolio
